# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated allowed origins)
CLIENT_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3005,http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mabco_website

# Admin / Auth secrets
ADMIN_API_KEY=change_this_admin_key
OTP_SECRET=change_this_otp_secret_32+_chars
ADMIN_TOKEN_SECRET=change_this_jwt_secret_32+_chars
POS_SYNC_TOKEN=change_this_pos_sync_token_32+_chars
POS_SYNC_CONN_STRING=
POS_SYNC_TIMEOUT_MS=900000

# SMS OTP (optional for development, required in production)
SMS_USER=change_this_sms_user
SMS_PASS=change_this_sms_password
SMS_FROM=MABCO
SMS_LANG=0
